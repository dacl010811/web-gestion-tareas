{
  "name": "web-gestion-tareas",
  "version": "1.0.0",
  "description": "Sistema de Gestión de Tareas — Arquitectura MVC con Node.js y MySQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node db/seed.js",
    "test": "jest --runInBand --detectOpenHandles"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "keywords": [
    "gestion-tareas",
    "node.js",
    "mysql",
    "mvc",
    "crud"
  ],
  "author": "Damián",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "mysql2": "^3.5.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2",
    "supertest-session": "^5.0.1"
  }
}
